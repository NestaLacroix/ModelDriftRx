# Drift Watch env config:

# Drift Detection (PSI Thresholds)
PSI_NONE=0.1
PSI_LOW=0.2
PSI_MODERATE=0.3

# Drift Detection (KS Test)
KS_SIGNIFICANCE_LEVEL=0.05

# When to Trigger Healing
# Options: "moderate" or "severe"
HEALING_TRIGGER_SEVERITY=moderate

# Performance Monitoring
# Flag if accuracy drops more than this fraction (0.05 = 5%)
ACCURACY_DROP_THRESHOLD=0.05

# Champion vs. Challenger
# Challenger must be at least this much better to get promoted (0.02 = 2%)
MIN_IMPROVEMENT=0.02

# SHAP Explainability
SHAP_SAMPLE_SIZE=100

# Retraining
RETRAIN_WINDOW_SIZE=5000

# PSI Binning
PSI_NUM_BINS=10

# Paths
MODEL_DIR=models
MODEL_ARCHIVE_DIR=models/archive
REPORTS_DIR=reports
INCIDENT_STORE_PATH=reports/incidents.json

# MLflow
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=autopilot-ml